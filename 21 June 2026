public class UndoRedo {
    public static void main(String[] args) {

        int[] undo = new int[10];
        int[] redo = new int[10];

        int utop = -1;
        int rtop = -1;

        undo[++utop] = 10;
        undo[++utop] = 20;
        undo[++utop] = 30;

        System.out.print("Undo Stack: ");
        for (int i = utop; i >= 0; i--) {
            System.out.print(undo[i] + " ");
        }

        redo[++rtop] = undo[utop--];

        System.out.print("\nAfter Undo: ");
        for (int i = utop; i >= 0; i--) {
            System.out.print(undo[i] + " ");
        }

        undo[++utop] = redo[rtop--];

        System.out.print("\nAfter Redo: ");
        for (int i = utop; i >= 0; i--) {
            System.out.print(undo[i] + " ");
        }
    }
}
