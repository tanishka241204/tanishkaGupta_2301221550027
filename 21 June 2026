class Solution {
    public boolean isValid(String s) {
        char[] stack = new char[10000];
        int top = -1;

        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);

            if (ch == '(' || ch == '{' || ch == '[') {
                stack[++top] = ch;
            } else {

                if (top == -1)
                    return false;

                if ((ch == ')' && stack[top] == '(') ||
                    (ch == '}' && stack[top] == '{') ||
                    (ch == ']' && stack[top] == '[')) {
                    top--;
                } else {
                    return false;
                }
            }
        }

        return top == -1;
    }
}
